        // 7. SISTEMA DE TOASTS PERSONALIZADO (SEM USAR ALERT DO NAVEGADOR)
        function showToast(message, type = 'success') {
            const container = document.getElementById('toast-container');
            if(!container) return;
            const toast = document.createElement('div');
            
            const bgColor = type === 'success' ? 'bg-[#141416] border-brandAcid/30' : 'bg-[#1D1014] border-red-500/20';
            const iconColor = type === 'success' ? 'text-brandAcid' : 'text-red-500';
            const iconName = type === 'success' ? 'check-circle' : 'alert-circle';

            toast.className = `${bgColor} border px-5 py-4 rounded shadow-2xl flex items-center gap-3 animate-slide-up pointer-events-auto min-w-[300px] text-sm text-white`;
            
            toast.innerHTML = `
                <i data-lucide="${iconName}" class="${iconColor} w-5 h-5 shrink-0"></i>
                <div class="flex-1 font-medium">${message}</div>
                <button class="text-gray-500 hover:text-white transition-colors" onclick="this.parentElement.remove()"><i data-lucide="x" class="w-4 h-4"></i></button>
            `;

            container.appendChild(toast);
            lucide.createIcons();

            setTimeout(() => {
                toast.classList.add('opacity-0', 'translate-y-[-10px]', 'transition-all', 'duration-300');
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

