        function toggleCart() {
            const sidebar = document.getElementById('cart-sidebar');
            const inner = document.getElementById('cart-panel');
            
            if (sidebar.classList.contains('opacity-0')) {
                sidebar.classList.remove('opacity-0', 'pointer-events-none');
                inner.classList.remove('translate-x-full');
                document.body.classList.add('no-scroll');
            } else {
                sidebar.classList.add('opacity-0', 'pointer-events-none');
                inner.classList.add('translate-x-full');
                document.body.classList.remove('no-scroll');
            }
        }

        function quickAddToCart(productId) {
            addToCart(productId, 'M'); 
        }

        function addToCart(productId, size) {
            const product = products.find(p => p.id === productId);
            if (!product) return;

            const existingItemIndex = cart.findIndex(item => item.id === productId && item.size === size);

            if (existingItemIndex > -1) {
                cart[existingItemIndex].quantity += 1;
            } else {
                cart.push({
                    id: product.id,
                    size: size,
                    quantity: 1
                });
            }

            saveCartToStorage();
            showToast(`${product.name} (${size}) adicionado ao carrinho!`, 'success');
        }

        function updateCartQuantity(productId, size, offset) {
            const index = cart.findIndex(item => item.id === productId && item.size === size);
            if (index === -1) return;

            cart[index].quantity += offset;

            if (cart[index].quantity <= 0) {
                cart.splice(index, 1);
            }

            saveCartToStorage();
        }

        function removeCartItem(productId, size) {
            cart = cart.filter(item => !(item.id === productId && item.size === size));
            saveCartToStorage();
            showToast('Item removido do carrinho.', 'success');
        }

        function clearCart() {
            cart = [];
            saveCartToStorage();
            showToast('Carrinho limpo!', 'success');
        }

